---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  reverse?: boolean;
  index: number;
}

const { project, reverse = false, index } = Astro.props;
---

<section class={`project-feature ${reverse ? 'project-feature--reverse' : ''}`} id={project.slug}>
  <div class="project-feature__inner">

    <!-- Text side -->
    <div class="project-feature__text">
      <div class="project-feature__tags">
        {project.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
        {project.platform && (
          <span class="tag tag--platform">{project.platform}</span>
        )}
      </div>

      <span class="project-feature__number">0{index + 1}</span>

      <h2 class="project-feature__name">{project.name}</h2>
      <p class="project-feature__tagline">{project.tagline}</p>
      <p class="project-feature__description">{project.description}</p>

      <ul class="project-feature__strengths">
        {project.strengths.map((s) => (
          <li class="strength-item">
            <span class="strength-bullet" aria-hidden="true"></span>
            {s}
          </li>
        ))}
      </ul>

      {project.url && project.urlLabel ? (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class="project-feature__cta"
        >
          <span>{project.ctaLabel ?? `Visit ${project.urlLabel}`}</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ) : (
        <div class="project-feature__status">Captured from a fresh local build for portfolio review.</div>
      )}
    </div>

    <!-- Image side -->
    <div class="project-feature__visual">
      <div class="browser-frame">
        <div class="browser-frame__chrome">
          <div class="browser-dots">
            <span class="dot dot--red"></span>
            <span class="dot dot--yellow"></span>
            <span class="dot dot--green"></span>
          </div>
          <div class="browser-url">
            <span>{project.urlLabel ?? 'Local build'}</span>
          </div>
        </div>
        <div class="browser-frame__content">
          <img
            src={project.screenshot}
            alt={project.screenshotAlt}
            loading={index === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
        </div>
      </div>

      {project.gallery && project.gallery.length > 0 && (
        <div class="project-feature__gallery" aria-label={`${project.name} supporting screenshots`}>
          {project.gallery.map((item) => (
            <figure class="gallery-card">
              <div class="gallery-card__image-wrap">
                <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
              </div>
              {item.label && <figcaption class="gallery-card__label">{item.label}</figcaption>}
            </figure>
          ))}
        </div>
      )}

      <div class="frame-glow" aria-hidden="true"></div>
    </div>

  </div>
</section>

<style>
  .project-feature {
    padding: 5rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .project-feature:last-of-type {
    border-bottom: none;
  }

  .project-feature__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .project-feature--reverse .project-feature__inner {
    direction: rtl;
  }
  .project-feature--reverse .project-feature__text,
  .project-feature--reverse .project-feature__visual {
    direction: ltr;
  }

  /* Tags */
  .project-feature__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: var(--color-surface-2);
    color: var(--color-accent-gold);
    border: 1px solid var(--color-border);
  }

  .tag--platform {
    color: var(--color-muted);
    background: transparent;
    border-color: var(--color-border);
  }

  /* Section number */
  .project-feature__number {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-border);
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  /* Text */
  .project-feature__name {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .project-feature__tagline {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--color-accent);
    margin: 0 0 1.25rem;
    font-family: var(--font-heading);
  }

  .project-feature__description {
    font-size: 1.05rem;
    color: #b7b0aa;
    line-height: 1.8;
    margin: 0 0 2rem;
    max-width: 46ch;
  }

  /* Strengths list */
  .project-feature__strengths {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .strength-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-text);
    opacity: 0.92;
  }

  .strength-bullet {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  /* CTA link */
  .project-feature__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }
  .project-feature__cta:hover {
    border-color: var(--color-accent);
    background: var(--color-surface-2);
    color: var(--color-accent);
  }
  .project-feature__cta svg {
    transition: transform 0.2s;
  }
  .project-feature__cta:hover svg {
    transform: translateX(3px);
  }

  .project-feature__status {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: #b7b0aa;
    font-size: 0.92rem;
    background: rgba(255, 255, 255, 0.02);
  }

  /* Browser frame */
  .project-feature__visual {
    position: relative;
  }

  .browser-frame {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.04) inset,
      0 24px 64px rgba(0,0,0,0.6),
      0 8px 24px rgba(0,0,0,0.4);
    position: relative;
    z-index: 1;
  }

  .browser-frame__chrome {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 1rem;
    background: var(--color-surface-2);
    border-bottom: 1px solid var(--color-border);
  }

  .browser-dots {
    display: flex;
    gap: 5px;
    flex-shrink: 0;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot--red    { background: #ff5f57; }
  .dot--yellow { background: #febc2e; }
  .dot--green  { background: #28c840; }

  .browser-url {
    flex: 1;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 5px;
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    color: var(--color-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .browser-frame__content {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    display: flex;
  }

  .browser-frame__content img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  /* Glow behind frame */
  .project-feature__gallery {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.875rem;
    position: relative;
    z-index: 1;
  }

  .gallery-card {
    margin: 0;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-surface);
    box-shadow: 0 12px 30px rgba(0,0,0,0.22);
  }

  .gallery-card__image-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-surface-2);
  }

  .gallery-card__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .gallery-card__label {
    padding: 0.65rem 0.8rem;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
    background: rgba(255,255,255,0.02);
  }

  .frame-glow {
    position: absolute;
    inset: 20% 10%;
    background: radial-gradient(ellipse, rgba(232, 131, 74, 0.12), transparent 70%);
    border-radius: 50%;
    z-index: 0;
    pointer-events: none;
    filter: blur(24px);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .project-feature__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .project-feature--reverse .project-feature__inner {
      direction: ltr;
    }
    .project-feature__visual {
      order: -1;
    }
    .project-feature__description {
      max-width: 100%;
    }
  }

  @media (max-width: 560px) {
    .project-feature__gallery {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .project-feature {
      padding: 3.5rem 0;
    }
  }
</style>
