---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-logo">
        <span class="logo-word">Allegrow</span><span class="logo-accent">AI</span>
      </span>
      <span class="footer-domain">allegrowai.com</span>
    </div>
    <div class="footer-right">
      <span class="footer-copy">&copy; {year} AllegrowAI</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 2.5rem 0;
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.03em;
  }
  .logo-word { color: var(--color-text); }
  .logo-accent { color: var(--color-accent); }

  .footer-domain {
    font-size: 0.8125rem;
    color: var(--color-muted);
    border-left: 1px solid var(--color-border);
    padding-left: 1rem;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }
</style>
